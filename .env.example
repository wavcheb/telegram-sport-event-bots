# ===========================================
# Sport Event Bot Configuration
# ===========================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_DATABASE=futsal_bot
MYSQL_USER=futsal_bot
MYSQL_PASSWORD=your_password_here

# ===========================================
# Tournament Bot Configuration (optional)
# ===========================================
# If not set, tournament bot will use TELEGRAM_BOT_TOKEN
# TOURNAMENT_BOT_TOKEN=your_tournament_bot_token_here

# Tournament bot can use same or different database
# If not set, uses MYSQL_* values above
# TOURNAMENT_MYSQL_HOST=localhost
# TOURNAMENT_MYSQL_DATABASE=tournament_bot
# TOURNAMENT_MYSQL_USER=tournament_bot
# TOURNAMENT_MYSQL_PASSWORD=your_password_here
